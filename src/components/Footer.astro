---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Footer Columns -->
    <div class="footer-grid">
      <div class="footer-col footer-col--brand">
        <div class="footer-brand">Styled by Maryam</div>
        <p class="footer-tagline">Curated luxury. Timeless elegance. A world designed for the woman who knows her worth.</p>
        <div class="footer-social">
          <a href="https://www.instagram.com/styleddbymaryam/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" aria-label="TikTok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg>
          </a>
          <a href="#" aria-label="Pinterest">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M8 21c1.85-1.61 2.6-3.49 3-5.5l1.5-5.5a3 3 0 115 2l-1.5 5.5"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4 class="footer-col__title">Shop</h4>
        <ul>
          <li><a href="/shop">New In</a></li>
          <li><a href="/shop">Ready-to-Wear</a></li>
          <li><a href="/shop">Handbags</a></li>
          <li><a href="/shop">Accessories</a></li>
          <li><a href="/shop">Fragrances & Beauty</a></li>
          <li><a href="/shop">Gifts</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col__title">Help</h4>
        <ul>
          <li><a href="/contact">Contact Us</a></li>
          <li><a href="/checkout">Shipping & Delivery</a></li>
          <li><a href="/contact">Returns & Exchanges</a></li>
          <li><a href="/contact">Size Guide</a></li>
          <li><a href="/contact">FAQs</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col__title">World of Maryam</h4>
        <ul>
          <li><a href="/about">Our Story</a></li>
          <li><a href="/about">The Atelier</a></li>
          <li><a href="/about">Sustainability</a></li>
          <li><a href="/contact">Careers</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-copy">
        &copy; {currentYear} Styled by Maryam. All rights reserved.
      </div>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms & Conditions</a>
        <a href="#">Cookie Settings</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 0.5px solid var(--color-border);
    padding: 5rem 1.5rem 2.5rem;
    background: var(--color-black);
    color: var(--color-white);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }

  /* Brand column */
  .footer-col--brand {
    max-width: 320px;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-white);
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.8rem;
    line-height: 1.65;
    color: #999;
    margin-bottom: 1.5rem;
    letter-spacing: 0;
    text-transform: none;
    max-width: 280px;
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .footer-social a {
    color: #777;
    transition: color 0.2s;
  }

  .footer-social a:hover {
    color: var(--color-gold);
  }

  /* Link columns */
  .footer-col__title {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-white);
    margin-bottom: 1.25rem;
    font-style: normal;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col ul a {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: #888;
    transition: color 0.2s;
    letter-spacing: 0;
  }

  .footer-col ul a:hover {
    color: var(--color-gold);
  }

  /* Bottom */
  .footer-bottom {
    border-top: 0.5px solid #333;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-copy {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: #555;
    letter-spacing: 0.02em;
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: #555;
    transition: color 0.2s;
  }

  .footer-legal a:hover {
    color: var(--color-gold);
  }

  @media (min-width: 768px) {
    .site-footer {
      padding: 5rem 3rem 2.5rem;
    }

    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  @media (min-width: 1024px) {
    .site-footer {
      padding: 5rem 4rem 2.5rem;
    }
  }
</style>
