---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="brand">Styled by Maryam</a>

    <!-- Desktop Nav -->
    <nav class="nav-desktop" role="navigation" aria-label="Main navigation">
      <ul class="nav-desktop__list">
        {navItems.map((item, idx) => (
          <li class="nav-desktop__item" data-mega-idx={idx}>
            <a href={item.href} class="nav-desktop__link">{item.label}</a>
            {item.mega && (
              <div class="mega-menu" data-mega={idx}>
                <div class="mega-menu__inner">
                  <div class="mega-menu__columns">
                    {item.columns.map(col => (
                      <div class="mega-menu__col">
                        <h4 class="mega-menu__col-title">{col.title}</h4>
                        <ul class="mega-menu__col-links">
                          {col.links.map(link => (
                            <li><a href={link.href}>{link.label}</a></li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                  {item.features && item.features.length > 0 && (
                    <div class="mega-menu__features">
                      {item.features.map(feat => (
                        <a href={feat.link} class="mega-menu__feature">
                          <img src={feat.image} alt={feat.title} loading="lazy" />
                          <span class="mega-menu__feature-title">{feat.title}</span>
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <button class="cart-trigger" aria-label="Open shopping bag" onclick="window.openCart && window.openCart()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="cart-badge" id="cart-badge" style="display:none;">0</span>
      </button>

      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="nav-toggle__bar"></span>
        <span class="nav-toggle__bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav class="nav-mobile" id="nav-mobile" role="navigation" aria-label="Mobile navigation">
    <div class="nav-mobile__inner">
      <ul class="nav-mobile__list">
        {mobileLinks.map(link => (
          <li class="nav-mobile__item">
            <a href={link.href} class="nav-mobile__link">{link.label}</a>
          </li>
        ))}
      </ul>
      <div class="nav-mobile__footer">
        <a href="https://www.instagram.com/styleddbymaryam/" target="_blank" rel="noopener noreferrer" class="nav-mobile__social">
          Follow @styleddbymaryam
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 0.5px solid #E5E5E5;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    position: relative;
    z-index: 1002;
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--color-black);
    z-index: 1002;
    position: relative;
    white-space: nowrap;
  }

  /* ─── Header Actions ─── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 1002;
    position: relative;
  }

  .cart-trigger {
    position: relative;
    padding: 4px;
    color: var(--color-black);
    transition: opacity 0.2s;
  }

  .cart-trigger:hover { opacity: 0.6; }

  .cart-badge {
    position: absolute;
    top: -4px;
    right: -6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-gold);
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
    cursor: pointer;
    z-index: 1002;
    position: relative;
  }

  .nav-toggle__bar {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-black);
    transition: transform 0.3s var(--ease-luxury);
    transform-origin: center;
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* ─── Desktop Nav ─── */
  .nav-desktop {
    display: none;
  }

  .nav-desktop__list {
    display: flex;
    gap: 1.8rem;
    align-items: center;
  }

  .nav-desktop__item {
    position: relative;
  }

  .nav-desktop__link {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text);
    transition: color 0.3s var(--ease-luxury);
    padding: 0.5rem 0;
    display: block;
    white-space: nowrap;
  }

  .nav-desktop__link:hover {
    color: var(--color-gold);
  }

  /* ─── Mega Menu ─── */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 0.75rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s var(--ease-luxury), visibility 0.3s var(--ease-luxury);
  }

  .nav-desktop__item:hover .mega-menu,
  .nav-desktop__item.is-active .mega-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mega-menu__inner {
    background: var(--color-white);
    border: 0.5px solid var(--color-border);
    box-shadow: 0 12px 40px rgba(0,0,0,0.06);
    display: flex;
    gap: 2.5rem;
    padding: 2rem 2.5rem;
    min-width: 620px;
    max-width: 820px;
  }

  .mega-menu__columns {
    display: flex;
    gap: 2.5rem;
    flex: 1;
  }

  .mega-menu__col {
    min-width: 140px;
  }

  .mega-menu__col-title {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-black);
    margin-bottom: 1rem;
    font-style: normal;
  }

  .mega-menu__col-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .mega-menu__col-links a {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: #666;
    transition: color 0.2s;
    letter-spacing: 0;
  }

  .mega-menu__col-links a:hover {
    color: var(--color-gold);
  }

  /* Feature cards in mega menu */
  .mega-menu__features {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .mega-menu__feature {
    display: block;
    width: 150px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }

  .mega-menu__feature img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3 / 4;
    transition: transform 0.5s var(--ease-luxury), filter 0.5s var(--ease-luxury);
  }

  .mega-menu__feature:hover img {
    transform: scale(1.05);
    filter: brightness(1.05);
  }

  .mega-menu__feature-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 0.65rem 0.65rem;
    background: linear-gradient(transparent, rgba(0,0,0,0.55));
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-white);
    letter-spacing: 0.02em;
    line-height: 1.3;
  }

  /* ─── Mobile Nav ─── */
  .nav-mobile {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background: var(--color-white);
    z-index: 1001;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s var(--ease-luxury), visibility 0.4s var(--ease-luxury);
    overflow-y: auto;
  }

  .nav-mobile.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .nav-mobile__inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
    padding: 6rem 2rem 3rem;
  }

  .nav-mobile__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nav-mobile__item {
    border-bottom: 0.5px solid var(--color-border);
  }

  .nav-mobile__item:first-child {
    border-top: 0.5px solid var(--color-border);
  }

  .nav-mobile__link {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-black);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.15rem 0;
    transition: color 0.2s;
  }

  .nav-mobile__link::after {
    content: '→';
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-style: normal;
    color: var(--color-text-muted);
    transition: color 0.2s, transform 0.2s var(--ease-luxury);
  }

  .nav-mobile__link:hover {
    color: var(--color-gold);
  }

  .nav-mobile__link:hover::after {
    color: var(--color-gold);
    transform: translateX(4px);
  }

  .nav-mobile__footer {
    margin-top: 2.5rem;
    text-align: center;
  }

  .nav-mobile__social {
    font-family: var(--font-body);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .nav-mobile__social:hover {
    color: var(--color-gold);
  }

  /* ─── Responsive ─── */
  @media (min-width: 1024px) {
    .nav-toggle {
      display: none;
    }

    .nav-mobile {
      display: none;
    }

    .nav-desktop {
      display: block;
    }

    .header-inner {
      padding: 0.9rem 3rem;
    }
  }

  @media (min-width: 1280px) {
    .header-inner {
      padding: 0.9rem 4rem;
    }

    .nav-desktop__list {
      gap: 2.2rem;
    }
  }
</style>

<script>
  // Mobile toggle
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('nav-mobile');
  const mobileLinks = mobileNav.querySelectorAll('.nav-mobile__link');

  function closeMobileMenu() {
    toggle.setAttribute('aria-expanded', 'false');
    mobileNav.classList.remove('is-open');
    document.body.classList.remove('nav-open');
  }

  toggle.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    if (expanded) {
      closeMobileMenu();
    } else {
      toggle.setAttribute('aria-expanded', 'true');
      mobileNav.classList.add('is-open');
      document.body.classList.add('nav-open');
    }
  });

  mobileLinks.forEach(link => link.addEventListener('click', closeMobileMenu));

  // Desktop mega menu — keep open while hovering
  const megaItems = document.querySelectorAll('.nav-desktop__item[data-mega-idx]');
  let megaTimeout;

  megaItems.forEach(item => {
    item.addEventListener('mouseenter', () => {
      clearTimeout(megaTimeout);
      megaItems.forEach(i => i.classList.remove('is-active'));
      item.classList.add('is-active');
    });

    item.addEventListener('mouseleave', () => {
      megaTimeout = setTimeout(() => {
        item.classList.remove('is-active');
      }, 150);
    });
  });
</script>
