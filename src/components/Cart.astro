<!-- Slide-over Cart -->
<div class="cart-backdrop" id="cart-backdrop"></div>
<aside class="cart-panel" id="cart-panel" aria-label="Shopping bag">
  <div class="cart-header">
    <h2 class="cart-title">Your Bag</h2>
    <button class="cart-close" id="cart-close" aria-label="Close bag">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="1" y1="1" x2="17" y2="17"/><line x1="17" y1="1" x2="1" y2="17"/>
      </svg>
    </button>
  </div>

  <div class="cart-body" id="cart-body">
    <div class="cart-empty" id="cart-empty">
      <p>Your bag is empty.</p>
      <a href="/shop" class="btn" style="margin-top: 1.5rem;">Continue Shopping</a>
    </div>
    <div class="cart-items" id="cart-items"></div>
  </div>

  <!-- Gift Note -->
  <div class="cart-gift" id="cart-gift-section" style="display:none;">
    <label class="gift-toggle">
      <input type="checkbox" id="gift-toggle-check" />
      <span class="gift-toggle__label">Add a gift note</span>
    </label>
    <div class="gift-note-wrap" id="gift-note-wrap" style="display:none;">
      <textarea
        class="input-luxury"
        id="gift-note"
        placeholder="Write your message here..."
        rows="3"
      ></textarea>
    </div>
  </div>

  <!-- Summary -->
  <div class="cart-footer" id="cart-footer" style="display:none;">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span id="cart-subtotal-amount">£0</span>
    </div>
    <p class="cart-shipping">Shipping calculated at checkout</p>
    <a href="/checkout" class="btn btn--gold cart-checkout-btn" onclick="window.closeCart && window.closeCart()">Proceed to Checkout</a>
  </div>
</aside>

<style>
  .cart-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cart-backdrop.is-open {
    opacity: 1;
    visibility: visible;
  }

  .cart-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 420px;
    max-width: 90vw;
    height: 100vh;
    height: 100dvh;
    background: var(--color-white);
    z-index: 2001;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cart-panel.is-open {
    transform: translateX(0);
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .cart-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 300;
    font-style: italic;
    margin: 0;
  }

  .cart-close {
    padding: 4px;
    color: var(--color-black);
    transition: opacity 0.2s;
  }

  .cart-close:hover {
    opacity: 0.5;
  }

  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 2rem;
  }

  .cart-empty {
    text-align: center;
    padding: 3rem 0;
  }

  .cart-empty p {
    color: var(--color-text-muted);
    margin: 0 auto;
  }

  /* Cart Items */
  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Gift Note */
  .cart-gift {
    padding: 1rem 2rem;
    border-top: 0.5px solid var(--color-border);
  }

  .gift-toggle {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
  }

  .gift-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-gold);
  }

  .gift-toggle__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text);
  }

  .gift-note-wrap {
    margin-top: 1rem;
  }

  .gift-note-wrap textarea {
    resize: none;
    line-height: 1.6;
  }

  /* Footer */
  .cart-footer {
    padding: 1.5rem 2rem;
    background: var(--color-bone);
    border-top: 0.5px solid var(--color-border);
  }

  .cart-subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .cart-subtotal span:first-child {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }

  .cart-subtotal span:last-child {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-black);
  }

  .cart-shipping {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .cart-checkout-btn {
    width: 100%;
    text-align: center;
  }
</style>

<script>
  // Cart state
  function getCart() {
    try { return JSON.parse(localStorage.getItem('sbm-cart') || '[]'); }
    catch { return []; }
  }

  function saveCart(items) {
    localStorage.setItem('sbm-cart', JSON.stringify(items));
    document.dispatchEvent(new CustomEvent('cart-updated', { detail: { items } }));
  }

  function formatPrice(p) {
    return new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP', minimumFractionDigits: 0 }).format(p);
  }

  function esc(str) {
    const d = document.createElement('div');
    d.textContent = str || '';
    return d.innerHTML;
  }

  // Global API
  window.addToCart = function(product) {
    const cart = getCart();
    const existing = cart.find(i => i.id === product.id);
    if (existing) { existing.qty += 1; }
    else { cart.push({ ...product, qty: 1 }); }
    saveCart(cart);
    renderCart();
    openCart();
  };

  window.removeFromCart = function(id) {
    saveCart(getCart().filter(i => i.id !== id));
    renderCart();
  };

  window.updateQty = function(id, delta) {
    const cart = getCart();
    const item = cart.find(i => i.id === id);
    if (item) {
      item.qty += delta;
      if (item.qty < 1) item.qty = 1;
    }
    saveCart(cart);
    renderCart();
  };

  // Render
  function renderCart() {
    const cart = getCart();
    const itemsEl = document.getElementById('cart-items');
    const emptyEl = document.getElementById('cart-empty');
    const footerEl = document.getElementById('cart-footer');
    const giftEl = document.getElementById('cart-gift-section');
    const subtotalEl = document.getElementById('cart-subtotal-amount');

    if (cart.length === 0) {
      emptyEl.style.display = 'block';
      itemsEl.innerHTML = '';
      footerEl.style.display = 'none';
      giftEl.style.display = 'none';
      return;
    }

    emptyEl.style.display = 'none';
    footerEl.style.display = 'block';
    giftEl.style.display = 'block';

    const subtotal = cart.reduce((sum, i) => sum + i.price * i.qty, 0);
    subtotalEl.textContent = formatPrice(subtotal);

    itemsEl.innerHTML = cart.map(item => `
      <div class="cart-line" style="display:flex;gap:1rem;align-items:flex-start;padding-bottom:1.5rem;border-bottom:0.5px solid var(--color-border);">
        <div style="width:72px;height:90px;background:linear-gradient(180deg,#ece7df,#ddd6ca);flex-shrink:0;overflow:hidden;">
          ${item.image ? `<img src="${esc(item.image)}" alt="${esc(item.name)}" style="width:100%;height:100%;object-fit:cover;">` : ''}
        </div>
        <div style="flex:1;min-width:0;">
          <p style="font-family:var(--font-body);font-size:0.85rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-black);margin:0;">${esc(item.name)}</p>
          <p style="font-family:var(--font-display);font-size:1.05rem;font-style:italic;font-weight:300;color:#555;margin:0.25rem 0 0.75rem;">${formatPrice(item.price)}</p>
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <button onclick="window.updateQty('${esc(item.id)}',-1)" style="font-size:0.85rem;padding:2px 6px;border:0.5px solid var(--color-border);background:transparent;cursor:pointer;">−</button>
            <span style="font-size:0.85rem;min-width:1.5ch;text-align:center;">${item.qty}</span>
            <button onclick="window.updateQty('${esc(item.id)}',1)" style="font-size:0.85rem;padding:2px 6px;border:0.5px solid var(--color-border);background:transparent;cursor:pointer;">+</button>
            <button onclick="window.removeFromCart('${esc(item.id)}')" style="margin-left:auto;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-text-muted);cursor:pointer;background:none;border:none;">Remove</button>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Open / Close
  function openCart() {
    document.getElementById('cart-panel').classList.add('is-open');
    document.getElementById('cart-backdrop').classList.add('is-open');
    document.body.classList.add('cart-open');
  }

  function closeCart() {
    document.getElementById('cart-panel').classList.remove('is-open');
    document.getElementById('cart-backdrop').classList.remove('is-open');
    document.body.classList.remove('cart-open');
  }

  window.openCart = openCart;
  window.closeCart = closeCart;

  document.getElementById('cart-close').addEventListener('click', closeCart);
  document.getElementById('cart-backdrop').addEventListener('click', closeCart);

  // Gift note toggle
  document.getElementById('gift-toggle-check').addEventListener('change', (e) => {
    document.getElementById('gift-note-wrap').style.display = e.target.checked ? 'block' : 'none';
  });

  // Update header badge
  document.addEventListener('cart-updated', (e) => {
    const badge = document.getElementById('cart-badge');
    const count = e.detail.items.reduce((s, i) => s + i.qty, 0);
    if (badge) {
      badge.textContent = count;
      badge.style.display = count > 0 ? 'flex' : 'none';
    }
  });

  // Init
  renderCart();
  const initCart = getCart();
  if (initCart.length > 0) {
    document.dispatchEvent(new CustomEvent('cart-updated', { detail: { items: initCart } }));
  }
</script>
