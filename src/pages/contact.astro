---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const contactEntry = await getEntry('pages', 'contact');
const { Content } = await render(contactEntry);
const { title, description } = contactEntry.data;
---

<BaseLayout title={title} description={description}>
  <section class="page-hero section--hero">
    <div class="container">
      <p class="page-hero__caption reveal">Enquiries</p>
      <h1 class="reveal reveal--delay-1">Contact</h1>
      <div class="divider reveal reveal--delay-2"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-text prose reveal">
          <Content />
        </div>
        <div class="contact-form-wrap reveal reveal--delay-2">
          <form class="contact-form" name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" class="input-luxury" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" class="input-luxury" placeholder="you@example.com" required />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" class="input-luxury" placeholder="How can we help?" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" class="input-luxury" placeholder="Your message..." required></textarea>
            </div>
            <button type="submit" class="btn btn--filled" style="margin-top: 0.5rem;">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero__caption {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .contact-form {
    max-width: 500px;
  }

  .form-group {
    margin-bottom: 2rem;
  }

  .form-group label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .form-group textarea {
    resize: vertical;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
</style>
