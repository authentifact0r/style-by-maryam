---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const contactEntry = await getEntry('pages', 'contact');
const { Content } = await render(contactEntry);
const { title, description } = contactEntry.data;
---

<BaseLayout title={title} description={description}>
  <section class="page-hero section--hero">
    <div class="container">
      <p class="page-hero__caption">Enquiries</p>
      <h1>Contact</h1>
      <div class="divider"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-text prose">
          <Content />
        </div>
        <div class="contact-form-wrap">
          <form class="contact-form" name="contact" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="contact" />
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="6" required></textarea>
            </div>
            <button type="submit" class="btn btn--filled">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero__caption {
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999;
    margin-bottom: 1.5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  /* Form Styles */
  .contact-form {
    max-width: 500px;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border: 1px solid #ddd;
    background: #fff;
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    font-size: 0.95rem;
    color: #333;
    transition: border-color 0.2s ease;
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #c9b99a;
  }

  .form-group textarea {
    resize: vertical;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
</style>
