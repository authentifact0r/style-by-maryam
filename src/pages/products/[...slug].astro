<script>
  // Gallery thumbnail switching
  const mainImg = document.getElementById('main-image') as HTMLImageElement;
  const thumbs = document.querySelectorAll('.gallery__thumb');

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      thumbs.forEach(t => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
      if (mainImg) {
        mainImg.style.opacity = '0';
        setTimeout(() => {
          mainImg.src = (thumb as HTMLElement).dataset.src!;
          mainImg.style.opacity = '1';
        }, 150);
      }
    });
  });

  // Image zoom on hover — follow mouse
  const galleryMain = document.getElementById('gallery-zoom-container');
  if (galleryMain && mainImg) {
    galleryMain.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = galleryMain.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      mainImg.style.transformOrigin = `${x}% ${y}%`;
    });

    galleryMain.addEventListener('mouseleave', () => {
      mainImg.style.transformOrigin = 'center center';
    });
  }

  // Color swatches
  const swatches = document.querySelectorAll('.swatch');
  const colorName = document.getElementById('color-name');

  swatches.forEach(s => {
    s.addEventListener('click', () => {
      swatches.forEach(sw => sw.classList.remove('is-active'));
      s.classList.add('is-active');
      if (colorName) colorName.textContent = (s as HTMLElement).dataset.color!;
    });
  });

  // Size buttons
  const sizeBtns = document.querySelectorAll('.size-btn');
  sizeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      sizeBtns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  });

  // Add to Bag
  document.querySelectorAll('.add-to-bag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const product = JSON.parse((btn as HTMLElement).dataset.product!);
      const activeColor = document.querySelector('.swatch.is-active') as HTMLElement;
      const activeSize = document.querySelector('.size-btn.is-active') as HTMLElement;
      if (activeColor) product.color = activeColor.dataset.color;
      if (activeSize) product.size = activeSize.dataset.size;
      product.id = `${product.id}-${product.color || 'default'}-${product.size || 'default'}`;
      if ((window as any).addToCart) (window as any).addToCart(product);
    });
  });
</script>
