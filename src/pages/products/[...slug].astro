---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

function formatPrice(price) {
  return new Intl.NumberFormat('en-GB', {
    style: 'currency',
    currency: 'GBP',
    minimumFractionDigits: 0,
  }).format(price);
}

const categoryLabels = {
  'evening': 'Evening',
  'ready-to-wear': 'Ready-to-Wear',
  'accessories': 'Accessories',
};

const productData = JSON.stringify({
  id: product.id,
  name: product.data.name,
  price: product.data.price,
  image: product.data.image || '',
  category: product.data.category,
});
---

<BaseLayout title={`${product.data.name} — Styled by Maryam`} description={product.data.description}>
  <section class="product-detail">
    <div class="container">
      <nav class="breadcrumb reveal" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb__sep">/</span>
        <a href="/shop">Shop</a>
        <span class="breadcrumb__sep">/</span>
        <span>{product.data.name}</span>
      </nav>

      <div class="product-layout">
        <div class="product-image reveal">
          {product.data.image ? (
            <img src={product.data.image} alt={product.data.name} />
          ) : (
            <div class="product-image__placeholder">
              <span class="caption">{product.data.category}</span>
            </div>
          )}
        </div>

        <div class="product-info reveal reveal--delay-2">
          <p class="product-info__category">{categoryLabels[product.data.category]}</p>
          <h1 class="product-info__name">{product.data.name}</h1>
          <div class="accent-line"></div>
          <p class="product-info__price">{formatPrice(product.data.price)}</p>
          <p class="product-info__desc">{product.data.description}</p>

          {product.data.soldOut ? (
            <span class="btn product-info__sold-out">Sold Out</span>
          ) : (
            <button
              class="btn btn--filled add-to-bag-btn"
              data-product={productData}
            >
              Add to Bag
            </button>
          )}

          <div class="product-body prose">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .product-detail {
    padding-top: 7rem;
    padding-bottom: 5rem;
  }

  .breadcrumb {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--color-gold);
  }

  .breadcrumb__sep {
    margin: 0 0.5rem;
    color: #ddd;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .product-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .product-image__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: linear-gradient(180deg, #f0ece6 0%, #e5dfd6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-info__category {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .product-info__name {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    letter-spacing: 0.02em;
    margin-bottom: 0;
  }

  .product-info__price {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 300;
    color: #666;
    margin: 1.5rem 0;
  }

  .product-info__desc {
    margin-bottom: 2rem;
  }

  .product-info__sold-out {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  .product-body {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 0.5px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .product-detail {
      padding-top: 9rem;
      padding-bottom: 7rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.add-to-bag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const product = JSON.parse(btn.dataset.product);
      if (window.addToCart) window.addToCart(product);
    });
  });
</script>
