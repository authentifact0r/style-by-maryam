---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product, allProducts: products },
  }));
}

const { product, allProducts } = Astro.props;
const { Content } = await render(product);

function formatPrice(price) {
  return new Intl.NumberFormat('en-GB', {
    style: 'currency',
    currency: 'GBP',
    minimumFractionDigits: 0,
  }).format(price);
}

const categoryLabels = {
  'evening': 'Evening',
  'ready-to-wear': 'Ready-to-Wear',
  'accessories': 'Accessories',
};

const gallery = product.data.images || (product.data.image ? [product.data.image] : []);
const colors = product.data.colors || [];
const sizes = product.data.sizes || [];

// Related products: same category, exclude self, max 4
const related = allProducts
  .filter(p => p.data.category === product.data.category && p.id !== product.id)
  .slice(0, 4);

// Also explore: different category, max 4
const explore = allProducts
  .filter(p => p.data.category !== product.data.category)
  .slice(0, 4);

const productData = JSON.stringify({
  id: product.id,
  name: product.data.name,
  price: product.data.price,
  image: product.data.image || '',
  category: product.data.category,
});

// Fit details — per-product overrides possible via frontmatter, fallback for dresses
const isSoleil = product.id.includes('soleil');
const isDress = product.data.category === 'evening';
const fitDetails = isDress ? [
  { label: 'Bust', icon: '👗', value: isSoleil ? 'Great for any cup size.' : 'Standard fit through bust.' },
  { label: 'Waist', icon: '📐', value: isSoleil ? 'Fitted — very fitted at natural waist.' : 'Fitted at natural waist.' },
  { label: 'Hip', icon: '✨', value: isSoleil ? 'Loosely fitted.' : 'Relaxed through hip.' },
  { label: 'Undergarments', icon: '🩱', value: isSoleil ? 'May be worn with a strapless bra, adhesive bra, petals, or no bra.' : 'Standard undergarments recommended.' },
  { label: 'Fabric', icon: '🧵', value: isSoleil ? 'Fabric has no stretch.' : 'Minimal stretch.' },
  { label: 'Length', icon: '📏', value: isSoleil ? 'Mid-thigh. Size M measures approximately 35" from shoulder to hem.' : 'Standard length for category.' },
] : null;

// Sample reviews data
const reviews = [
  {
    name: 'Amara K.',
    rating: 5,
    date: '2026-03-18',
    title: 'Absolutely stunning',
    body: 'The quality of this dress is incredible — the fabric has a beautiful weight and the tailoring is impeccable. I wore this to a cocktail event and received so many compliments. True to size.',
    fit: 'True to Size',
    size: 'S',
    color: 'Lemon Sorbet',
    image: gallery[0] || null,
  },
  {
    name: 'Sophie R.',
    rating: 5,
    date: '2026-03-12',
    title: 'A showstopper',
    body: 'I\'ve been eyeing this dress for weeks and finally pulled the trigger. It did not disappoint! The one-shoulder silhouette is so flattering and the colour is even more vibrant in person.',
    fit: 'True to Size',
    size: 'M',
    color: 'Lemon Sorbet',
    image: gallery[1] || null,
  },
  {
    name: 'Priya M.',
    rating: 4,
    date: '2026-02-28',
    title: 'Beautiful but runs small',
    body: 'Gorgeous dress, the construction is top-notch. I would say it runs slightly small — I\'m usually between S and M and the M fits perfectly. Size up if you\'re between sizes.',
    fit: 'Runs a Little Small',
    size: 'M',
    color: 'Lemon Sorbet',
    image: null,
  },
  {
    name: 'Olivia T.',
    rating: 5,
    date: '2026-02-15',
    title: 'Worth every penny',
    body: 'The attention to detail on this piece is remarkable. From the invisible zipper to the boning in the bodice — you can feel the craftsmanship. The yellow is so chic for spring.',
    fit: 'True to Size',
    size: 'XS',
    color: 'Lemon Sorbet',
    image: gallery[2] || null,
  },
];

const avgRating = (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1);
const ratingCounts = [5,4,3,2,1].map(n => ({ stars: n, count: reviews.filter(r => r.rating === n).length }));
---

<BaseLayout title={`${product.data.name} — Styled by Maryam`} description={product.data.description}>
  <section class="product-detail">
    <div class="container">
      <nav class="breadcrumb reveal" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/shop">Shop</a>
        <span class="sep">/</span>
        <a href="/shop">{categoryLabels[product.data.category]}</a>
        <span class="sep">/</span>
        <span>{product.data.name}</span>
      </nav>

      <div class="product-layout">
        <!-- Image Gallery -->
        <div class="gallery reveal">
          <div class="gallery__main" id="gallery-zoom-container">
            <img
              id="main-image"
              src={gallery[0] || ''}
              alt={product.data.name}
              class="gallery__main-img"
            />
            <div class="gallery__zoom-lens" id="zoom-lens"></div>
          </div>
          {gallery.length > 1 && (
            <div class="gallery__thumbs">
              {gallery.map((img, i) => (
                <button
                  class={`gallery__thumb ${i === 0 ? 'is-active' : ''}`}
                  data-src={img}
                  aria-label={`View image ${i + 1}`}
                >
                  <img src={img} alt={`${product.data.name} view ${i + 1}`} loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div class="product-info reveal reveal--delay-2">
          <p class="product-info__category">{categoryLabels[product.data.category]}</p>
          <h1 class="product-info__name">{product.data.name}</h1>
          <div class="accent-line"></div>
          <p class="product-info__price">{formatPrice(product.data.price)}</p>
          <p class="product-info__desc">{product.data.description}</p>

          <!-- Color Selector -->
          {colors.length > 0 && (
            <div class="variant-group">
              <label class="variant-label">Colour — <span id="color-name">{colors[0].name}</span></label>
              <div class="color-swatches">
                {colors.map((c, i) => (
                  <button
                    class={`swatch ${i === 0 ? 'is-active' : ''}`}
                    style={`background:${c.hex};`}
                    data-color={c.name}
                    aria-label={c.name}
                  >
                    {c.hex === '#FFFFF0' || c.hex === '#F5F0E1' || c.hex === '#E8DCC8' || c.hex === '#F7E7CE' ? (
                      <span class="swatch__border"></span>
                    ) : null}
                  </button>
                ))}
              </div>
            </div>
          )}

          <!-- Size Selector -->
          {sizes.length > 0 && sizes[0] !== 'One Size' && (
            <div class="variant-group">
              <label class="variant-label">Size</label>
              <div class="size-options">
                {sizes.map((s, i) => (
                  <button class={`size-btn ${i === 0 ? 'is-active' : ''}`} data-size={s}>
                    {s}
                  </button>
                ))}
              </div>
            </div>
          )}

          {sizes.length > 0 && sizes[0] === 'One Size' && (
            <div class="variant-group">
              <label class="variant-label">Size — One Size</label>
            </div>
          )}

          <!-- Add to Bag -->
          {product.data.soldOut ? (
            <button class="btn product-info__sold-out" disabled>Sold Out</button>
          ) : (
            <button class="btn btn--filled add-to-bag-btn" data-product={productData}>
              Add to Bag
            </button>
          )}

          <div class="product-details-accordion">
            <details>
              <summary>Product Details</summary>
              <div class="prose details-content">
                <Content />
              </div>
            </details>

            <!-- Fit Guide -->
            {fitDetails && (
              <details>
                <summary>Fit Guide</summary>
                <div class="details-content fit-guide">
                  {fitDetails.map(fd => (
                    <div class="fit-row">
                      <div class="fit-row__label">
                        <span class="fit-row__icon">{fd.icon}</span>
                        <span class="fit-row__name">{fd.label}</span>
                      </div>
                      <p class="fit-row__value">{fd.value}</p>
                    </div>
                  ))}
                </div>
              </details>
            )}

            <details>
              <summary>Shipping & Returns</summary>
              <div class="details-content">
                <p>Complimentary standard shipping on all orders over £200. Express delivery available at checkout. Returns accepted within 14 days of delivery — items must be unworn with tags attached.</p>
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Customer Reviews -->
  <section class="section reviews-section">
    <div class="container">
      <div class="text-center">
        <p class="caption reveal">What Our Customers Say</p>
        <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
        <h2 class="reveal reveal--delay-2">Customer Reviews</h2>
      </div>

      <div class="reviews-overview reveal">
        <!-- Rating Summary -->
        <div class="reviews-summary">
          <div class="reviews-summary__score">
            <span class="reviews-summary__number">{avgRating}</span>
            <div class="reviews-summary__stars">
              {[1,2,3,4,5].map(s => (
                <span class={`star ${s <= Math.round(parseFloat(avgRating)) ? 'star--filled' : ''}`}>★</span>
              ))}
            </div>
            <span class="reviews-summary__count">{reviews.length} Reviews</span>
          </div>
          <div class="reviews-summary__bars">
            {ratingCounts.map(rc => (
              <div class="rating-bar">
                <span class="rating-bar__label">{rc.stars} Stars</span>
                <div class="rating-bar__track">
                  <div class="rating-bar__fill" style={`width: ${reviews.length > 0 ? (rc.count / reviews.length) * 100 : 0}%`}></div>
                </div>
                <span class="rating-bar__count">{rc.count}</span>
              </div>
            ))}
          </div>
          <div class="reviews-summary__fit">
            <span class="reviews-summary__fit-label">Fit: True to Size</span>
            <div class="fit-scale">
              <div class="fit-scale__track">
                <div class="fit-scale__marker" style="left: 50%;"></div>
              </div>
              <div class="fit-scale__labels">
                <span>Runs Small</span>
                <span>True to Size</span>
                <span>Runs Large</span>
              </div>
            </div>
            <span class="reviews-summary__basis">Based on {reviews.length} Reviews</span>
          </div>
        </div>

        <!-- Customer Images -->
        {gallery.length > 0 && (
          <div class="customer-images">
            <div class="customer-images__header">
              <h3>Customer Images</h3>
              <span class="customer-images__count">View All ({gallery.length}) Photos</span>
            </div>
            <div class="customer-images__grid">
              {gallery.map((img, i) => (
                <div class="customer-images__item" data-src={img}>
                  <img src={img} alt={`Customer photo ${i + 1}`} loading="lazy" />
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Individual Reviews -->
      <div class="reviews-list reveal">
        <div class="reviews-list__controls">
          <span class="reviews-list__sort">Sort By: <strong>Featured</strong></span>
        </div>

        {reviews.map(review => (
          <div class="review-card">
            <div class="review-card__header">
              <div class="review-card__stars">
                {[1,2,3,4,5].map(s => (
                  <span class={`star ${s <= review.rating ? 'star--filled' : ''}`}>★</span>
                ))}
              </div>
              <span class="review-card__date">{new Date(review.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
            <h4 class="review-card__title">{review.title}</h4>
            <p class="review-card__body">{review.body}</p>
            {review.image && (
              <div class="review-card__image">
                <img src={review.image} alt={`Review by ${review.name}`} loading="lazy" />
              </div>
            )}
            <div class="review-card__footer">
              <span class="review-card__name">{review.name}</span>
              <div class="review-card__tags">
                {review.fit && <span class="review-tag">Fit: {review.fit}</span>}
                {review.size && <span class="review-tag">Size: {review.size}</span>}
                {review.color && <span class="review-tag">Color: {review.color}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- You May Also Like -->
  {related.length > 0 && (
    <section class="section related-section">
      <div class="container">
        <div class="text-center">
          <p class="caption reveal">Complete the Look</p>
          <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
          <h2 class="reveal reveal--delay-2">You May Also Like</h2>
        </div>
        <div class="related-grid">
          {related.map((item, i) => (
            <a href={`/products/${item.id}`} class={`related-card reveal reveal--delay-${i + 1}`}>
              <div class="related-card__image">
                {item.data.image ? (
                  <img src={item.data.image} alt={item.data.name} loading="lazy" />
                ) : (
                  <span class="caption">{item.data.category}</span>
                )}
              </div>
              <h3>{item.data.name}</h3>
              <span class="related-card__price">{formatPrice(item.data.price)}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Explore More -->
  {explore.length > 0 && (
    <section class="section explore-section">
      <div class="container">
        <div class="text-center">
          <p class="caption reveal">Discover</p>
          <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
          <h2 class="reveal reveal--delay-2">Explore More</h2>
        </div>
        <div class="related-grid">
          {explore.map((item, i) => (
            <a href={`/products/${item.id}`} class={`related-card reveal reveal--delay-${i + 1}`}>
              <div class="related-card__image">
                {item.data.image ? (
                  <img src={item.data.image} alt={item.data.name} loading="lazy" />
                ) : (
                  <span class="caption">{item.data.category}</span>
                )}
              </div>
              <h3>{item.data.name}</h3>
              <span class="related-card__price">{formatPrice(item.data.price)}</span>
            </a>
          ))}
        </div>
        <div class="text-center reveal" style="margin-top: 3rem;">
          <a href="/shop" class="btn">View All Products</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .product-detail {
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  .breadcrumb {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .breadcrumb a { color: var(--color-text-muted); transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--color-gold); }
  .sep { margin: 0 0.4rem; color: #ddd; }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  /* Gallery with zoom */
  .gallery__main {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-bone);
    position: relative;
    cursor: crosshair;
  }

  .gallery__main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-luxury), opacity 0.3s var(--ease-luxury);
    transform-origin: center center;
  }

  .gallery__main:hover .gallery__main-img {
    transform: scale(1.8);
  }

  .gallery__zoom-lens {
    display: none;
  }

  .gallery__thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .gallery__thumb {
    width: 64px;
    height: 80px;
    overflow: hidden;
    border: 1.5px solid transparent;
    padding: 0;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.3s, border-color 0.3s;
  }

  .gallery__thumb.is-active {
    opacity: 1;
    border-color: var(--color-black);
  }

  .gallery__thumb:hover { opacity: 1; }

  .gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Product Info */
  .product-info__category {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .product-info__name {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    margin-bottom: 0;
  }

  .product-info__price {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    font-style: normal;
    color: var(--color-black);
    margin: 1rem 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .product-info__desc {
    margin-bottom: 1.75rem;
    line-height: 1.7;
  }

  .product-info__sold-out {
    opacity: 0.35;
    cursor: not-allowed;
  }

  /* Variants */
  .variant-group {
    margin-bottom: 1.5rem;
  }

  .variant-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .variant-label span {
    color: var(--color-black);
  }

  /* Color Swatches */
  .color-swatches {
    display: flex;
    gap: 0.6rem;
  }

  .swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
    padding: 0;
  }

  .swatch.is-active {
    border-color: var(--color-black);
    transform: scale(1.1);
  }

  .swatch:hover { transform: scale(1.1); }

  .swatch__border {
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    border: 1px solid #ddd;
    pointer-events: none;
  }

  /* Size Options */
  .size-options {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .size-btn {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s var(--ease-luxury);
    color: var(--color-text);
  }

  .size-btn.is-active,
  .size-btn:hover {
    border-color: var(--color-black);
    background: var(--color-black);
    color: var(--color-white);
  }

  /* Add to Bag */
  .add-to-bag-btn {
    width: 100%;
    text-align: center;
    margin-bottom: 2rem;
    padding: 1.1rem 2rem;
  }

  /* Accordion */
  .product-details-accordion {
    border-top: 0.5px solid var(--color-border);
  }

  .product-details-accordion details {
    border-bottom: 0.5px solid var(--color-border);
  }

  .product-details-accordion summary {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 1.25rem 0;
    cursor: pointer;
    color: var(--color-text);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .product-details-accordion summary::-webkit-details-marker { display: none; }

  .product-details-accordion summary::after {
    content: '+';
    font-size: 1rem;
    font-weight: 300;
    transition: transform 0.3s;
  }

  .product-details-accordion details[open] summary::after {
    content: '\2212';
  }

  .details-content {
    padding-bottom: 1.5rem;
  }

  .details-content p {
    font-size: 0.85rem;
    line-height: 1.7;
  }

  /* Fit Guide */
  .fit-guide {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fit-row {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .fit-row:last-child { border-bottom: none; }

  .fit-row__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }

  .fit-row__icon {
    font-size: 0.85rem;
  }

  .fit-row__name {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-black);
  }

  .fit-row__value {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0;
    padding-left: 1.35rem;
  }

  /* ---- Reviews Section ---- */
  .reviews-section {
    background: var(--color-white);
    padding-bottom: 4rem;
  }

  .reviews-overview {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .reviews-summary {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
  }

  .reviews-summary__score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .reviews-summary__number {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    color: var(--color-black);
    line-height: 1;
  }

  .reviews-summary__stars {
    display: flex;
    gap: 0.15rem;
  }

  .star {
    font-size: 1rem;
    color: #ddd;
  }

  .star--filled {
    color: var(--color-gold);
  }

  .reviews-summary__count {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
  }

  .reviews-summary__bars {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .rating-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .rating-bar__label {
    width: 50px;
    flex-shrink: 0;
  }

  .rating-bar__track {
    flex: 1;
    height: 6px;
    background: #f0f0f0;
    border-radius: 3px;
    overflow: hidden;
  }

  .rating-bar__fill {
    height: 100%;
    background: var(--color-black);
    border-radius: 3px;
    transition: width 0.6s var(--ease-luxury);
  }

  .rating-bar__count {
