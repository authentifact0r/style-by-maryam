---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const shopEntry = await getEntry('pages', 'shop');
const { Content } = await render(shopEntry);
const { title, description } = shopEntry.data;

const allProducts = await getCollection('products');
const products = allProducts.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return 0;
});

const categories = [
  { slug: 'all', label: 'All' },
  { slug: 'evening', label: 'Evening' },
  { slug: 'ready-to-wear', label: 'Ready-to-Wear' },
  { slug: 'accessories', label: 'Accessories' },
];

function formatPrice(price) {
  return new Intl.NumberFormat('en-GB', {
    style: 'currency',
    currency: 'GBP',
    minimumFractionDigits: 0,
  }).format(price);
}
---

<BaseLayout title={title} description={description}>
  <section class="page-hero section--hero">
    <div class="container">
      <p class="page-hero__caption reveal">The Edit</p>
      <h1 class="reveal reveal--delay-1">Shop</h1>
      <div class="divider reveal reveal--delay-2"></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="shop-intro prose text-center reveal" style="max-width: 550px; margin: 0 auto 3rem;">
        <Content />
      </div>

      <nav class="filter-bar reveal" aria-label="Filter by category">
        {categories.map(cat => (
          <button
            class={`filter-btn ${cat.slug === 'all' ? 'is-active' : ''}`}
            data-filter={cat.slug}
          >
            {cat.label}
          </button>
        ))}
      </nav>

      <div class="product-grid">
        {products.map((product, i) => (
          <a
            href={`/products/${product.id}`}
            class={`product-card reveal reveal--delay-${(i % 3) + 1}`}
            data-category={product.data.category}
          >
            <div class="product-card__image">
              {product.data.image ? (
                <img src={product.data.image} alt={product.data.name} loading="lazy" />
              ) : (
                <span class="caption">{product.data.category}</span>
              )}
              {product.data.soldOut && (
                <span class="product-card__badge">Sold Out</span>
              )}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__name">{product.data.name}</h3>
              <span class="product-card__price">{formatPrice(product.data.price)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero__caption {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .filter-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    padding: 0.5rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.3s var(--ease-luxury), border-color 0.3s var(--ease-luxury);
  }

  .filter-btn:hover,
  .filter-btn.is-active {
    color: var(--color-black);
    border-bottom-color: var(--color-gold);
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .product-card {
    display: block;
    transition: opacity 0.3s var(--ease-luxury);
  }

  .product-card.is-hidden {
    display: none;
  }

  .product-card__image {
    position: relative;
    aspect-ratio: 4 / 5;
    background: linear-gradient(180deg, #f0ece6 0%, #e5dfd6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .product-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-luxury), filter 0.6s var(--ease-luxury);
  }

  .product-card:hover .product-card__image img {
    transform: scale(1.04);
    filter: brightness(1.05);
  }

  .product-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    background: var(--color-black);
    color: var(--color-white);
    padding: 0.35rem 0.85rem;
  }

  .product-card__info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .product-card__name {
    font-size: 0.75rem;
  }

  .product-card__price {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    font-weight: 300;
    color: #888;
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.classList.remove('is-hidden');
        } else {
          card.classList.add('is-hidden');
        }
      });
    });
  });
</script>
