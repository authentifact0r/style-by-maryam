---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Order Confirmed — Styled by Maryam" description="Thank you for your purchase">
  <section class="success-page">
    <div class="container">
      <div class="success-card reveal">
        <div class="success-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
            <circle cx="32" cy="32" r="32" fill="#C5A059" opacity="0.1"/>
            <circle cx="32" cy="32" r="24" fill="#C5A059" opacity="0.15"/>
            <path d="M22 33L29 40L42 25" stroke="#C5A059" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h1>Thank You for Your Order</h1>
        <p class="success-sub">Your payment has been processed successfully.</p>

        <div class="order-details" id="order-details">
          <p class="order-note">A confirmation email has been sent to your inbox with your order details and tracking information.</p>
        </div>

        <div class="success-actions">
          <a href="/shop" class="btn btn--filled">Continue Shopping</a>
          <a href="/" class="btn">Return Home</a>
        </div>

        <div class="success-help">
          <p>Questions about your order? Contact us at <a href="mailto:hello@styledbymaryam.com">hello@styledbymaryam.com</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .success-page {
    padding-top: 9rem;
    padding-bottom: 5rem;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .success-card {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .success-icon {
    margin-bottom: 2rem;
  }

  .success-card h1 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 0.75rem;
  }

  .success-sub {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .order-details {
    background: var(--color-bone);
    padding: 1.5rem 2rem;
    margin-bottom: 2.5rem;
    text-align: left;
  }

  .order-note {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
  }

  .success-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .success-actions .btn {
    min-width: 180px;
    text-align: center;
    padding: 0.9rem 2rem;
  }

  .success-help {
    border-top: 0.5px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .success-help p {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .success-help a {
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

<script>
  // Clear cart on success page load (in case redirect didn't clear it)
  localStorage.removeItem('sbm-cart');
  document.dispatchEvent(new CustomEvent('cart-updated', { detail: { items: [] } }));
</script>
