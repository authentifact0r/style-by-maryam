---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — Styled by Maryam" description="The page you are looking for does not exist.">
  <section class="not-found section--hero">
    <div class="container text-center">
      <p class="not-found__label">404</p>
      <h1>Page Not Found</h1>
      <div class="divider"></div>
      <p class="not-found__text">The page you are looking for may have been moved or no longer exists.</p>
      <a href="/" class="btn" style="margin-top: 2rem;">Return Home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .not-found__label {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 8rem);
    letter-spacing: 0.15em;
    color: var(--color-border);
    line-height: 1;
    margin-bottom: 1rem;
    font-style: normal;
    font-weight: 300;
  }

  .not-found__text {
    margin: 1rem auto 0;
    max-width: 400px;
  }
</style>
