---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const homeEntry = await getEntry('pages', 'home');
const { Content } = await render(homeEntry);

const { title, description } = homeEntry.data;
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero section--hero">
    <div class="container">
      <p class="hero__caption">Curated Luxury</p>
      <h1 class="hero__title">{title}</h1>
      <div class="divider"></div>
      <p class="hero__subtitle">Timeless elegance for the modern woman</p>
    </div>
  </section>

  <!-- Hero Image Band -->
  <section class="hero-image">
    <div class="hero-image__placeholder">
      <span class="caption">Editorial Image</span>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="section">
    <div class="container text-center">
      <p class="caption">The Ethos</p>
      <div class="accent-line" style="margin: 1rem auto;"></div>
      <div class="prose" style="max-width: 700px; margin: 0 auto;">
        <Content />
      </div>
    </div>
  </section>

  <!-- Featured Collections -->
  <section class="section collections">
    <div class="container">
      <div class="text-center">
        <p class="caption">Collections</p>
        <div class="accent-line" style="margin: 1rem auto;"></div>
        <h2>The Edit</h2>
      </div>
      <div class="collections__grid">
        <div class="collection-card">
          <div class="collection-card__image">
            <span class="caption">Evening Wear</span>
          </div>
          <h3 class="collection-card__title">Evening</h3>
        </div>
        <div class="collection-card">
          <div class="collection-card__image">
            <span class="caption">Ready to Wear</span>
          </div>
          <h3 class="collection-card__title">Ready-to-Wear</h3>
        </div>
        <div class="collection-card">
          <div class="collection-card__image">
            <span class="caption">Accessories</span>
          </div>
          <h3 class="collection-card__title">Accessories</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="section cta">
    <div class="container text-center">
      <h2>Explore the Collection</h2>
      <p style="margin: 1.5rem auto;">Discover pieces selected for their craft, quality, and quiet confidence.</p>
      <a href="/shop" class="btn" style="margin-top: 1rem;">Shop Now</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero__caption {
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    margin-bottom: 0;
  }

  .hero__subtitle {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: #666;
    margin-top: 0.5rem;
  }

  /* Hero Image */
  .hero-image__placeholder {
    width: 100%;
    height: 60vh;
    min-height: 300px;
    max-height: 700px;
    background: linear-gradient(135deg, #e8e2d8 0%, #d4cdc0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Collections Grid */
  .collections__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .collection-card {
    text-align: center;
  }

  .collection-card__image {
    aspect-ratio: 3 / 4;
    background: linear-gradient(180deg, #ece7df 0%, #ddd6ca 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: opacity 0.3s ease;
  }

  .collection-card:hover .collection-card__image {
    opacity: 0.85;
  }

  .collection-card__title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* CTA */
  .cta {
    background: #f5f1eb;
    padding: 6rem 0;
  }

  @media (min-width: 768px) {
    .collections__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .cta {
      padding: 8rem 0;
    }
  }
</style>
