---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const homeEntry = await getEntry('pages', 'home');
const { Content } = await render(homeEntry);

const { title, description } = homeEntry.data;

const allProducts = await getCollection('products');
const featured = allProducts.filter(p => p.data.featured);

function formatPrice(price) {
  return new Intl.NumberFormat('en-GB', {
    style: 'currency',
    currency: 'GBP',
    minimumFractionDigits: 0,
  }).format(price);
}
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero section--hero">
    <div class="container">
      <p class="hero__caption reveal">Curated Luxury</p>
      <h1 class="hero__title reveal reveal--delay-1">{title}</h1>
      <div class="divider reveal reveal--delay-2"></div>
      <p class="hero__subtitle reveal reveal--delay-3">Timeless elegance for the modern woman</p>
      <a href="/shop" class="btn hero__cta reveal reveal--delay-4">Explore the Collection</a>
    </div>
  </section>

  <!-- Hero Video Banner -->
  <section class="hero-video">
    <video autoplay muted loop playsinline class="hero-video__vid" poster="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=1600&q=80&fit=crop">
      <source src="https://videos.pexels.com/video-files/3753716/3753716-uhd_2560_1440_25fps.mp4" type="video/mp4" />
    </video>
    <div class="hero-video__overlay">
      <p class="hero-video__tagline">Curated for the woman who knows her worth</p>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="section">
    <div class="container text-center">
      <p class="caption reveal">The Ethos</p>
      <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
      <div class="prose reveal reveal--delay-2" style="max-width: 650px; margin: 0 auto;">
        <Content />
      </div>
    </div>
  </section>

  <!-- Featured Products — Asymmetric Editorial Grid -->
  <section class="section editorial-section">
    <div class="container">
      <div class="text-center">
        <p class="caption reveal">Selected Pieces</p>
        <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
        <h2 class="reveal reveal--delay-2">The Edit</h2>
      </div>
      <div class="editorial-grid">
        {featured.map((product, i) => (
          <a
            href={`/products/${product.id}`}
            class={`editorial-card editorial-card--${i + 1} reveal reveal--delay-${i + 1}`}
          >
            <div class="editorial-card__image">
              {product.data.image ? (
                <img src={product.data.image} alt={product.data.name} loading="lazy" />
              ) : (
                <span class="caption">{product.data.category}</span>
              )}
            </div>
            <div class="editorial-card__info">
              <h3>{product.data.name}</h3>
              <span class="editorial-card__price">{formatPrice(product.data.price)}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center reveal" style="margin-top: 3.5rem;">
        <a href="/shop" class="btn">View All</a>
      </div>
    </div>
  </section>

  <!-- Instagram Section -->
  <section class="section instagram-section">
    <div class="container text-center">
      <p class="caption reveal">Follow the Journey</p>
      <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
      <h2 class="reveal reveal--delay-2">@styleddbymaryam</h2>
      <p class="reveal reveal--delay-3" style="margin: 1rem auto 3rem; max-width: 450px;">Behind the scenes, styling tips, and new arrivals — straight from Maryam.</p>

      <div class="instagram-grid">
        <div class="instagram-embed reveal">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/styleddbymaryam/reel/DQMLfvQADQ_/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
        <div class="instagram-embed reveal reveal--delay-1">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/styleddbymaryam/reel/DP6QGIuiOs0/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
        <div class="instagram-embed reveal reveal--delay-2">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/styleddbymaryam/reel/DOaoOCmADyn/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
        <div class="instagram-embed reveal reveal--delay-3">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/styleddbymaryam/reel/DOBLAYTgB-Z/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
      </div>

      <a
        href="https://www.instagram.com/styleddbymaryam/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn reveal"
        style="margin-top: 3rem;"
      >
        Follow on Instagram
      </a>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="section cta">
    <div class="container text-center">
      <h2 class="reveal">Explore the Collection</h2>
      <p class="reveal reveal--delay-1" style="margin: 1.5rem auto;">Discover pieces selected for their craft, quality, and quiet confidence.</p>
      <a href="/shop" class="btn reveal reveal--delay-2" style="margin-top: 0.5rem;">Shop Now</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding-top: 12rem;
    padding-bottom: 4rem;
  }

  .hero__caption {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .hero__title {
    margin-bottom: 0;
  }

  .hero__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.2rem;
    color: #888;
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .hero__cta {
    margin-top: 0;
  }

  /* Hero Video */
  .hero-video {
    position: relative;
    width: 100%;
    height: 70vh;
    min-height: 350px;
    max-height: 800px;
    overflow: hidden;
  }

  .hero-video__vid {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-video__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    background: linear-gradient(transparent 50%, rgba(0,0,0,0.3));
    padding: 3rem 2rem;
  }

  .hero-video__tagline {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.4rem);
    font-style: italic;
    font-weight: 300;
    color: var(--color-white);
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0;
    max-width: none;
  }

  /* Asymmetric Editorial Grid */
  .editorial-section {
    background: var(--color-white);
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  .editorial-card {
    display: block;
    text-align: left;
  }

  .editorial-card__image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: linear-gradient(180deg, #f0ece6 0%, #e5dfd6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .editorial-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-luxury), filter 0.6s var(--ease-luxury);
  }

  .editorial-card:hover .editorial-card__image img {
    transform: scale(1.04);
    filter: brightness(1.05);
  }

  .editorial-card__info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .editorial-card__info h3 {
    font-size: 0.75rem;
  }

  .editorial-card__price {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    font-weight: 300;
    color: #888;
    white-space: nowrap;
  }

  /* Desktop: asymmetric layout */
  @media (min-width: 768px) {
    .hero {
      padding-top: 16rem;
      padding-bottom: 5rem;
    }

    .editorial-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-auto-rows: auto;
      gap: 1.5rem;
    }

    .editorial-card--1 {
      grid-column: 1 / 8;
      grid-row: 1 / 3;
    }

    .editorial-card--1 .editorial-card__image {
      aspect-ratio: 3 / 4;
      height: 100%;
    }

    .editorial-card--2 {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
    }

    .editorial-card--3 {
      grid-column: 8 / 13;
      grid-row: 2 / 3;
    }
  }

  /* Instagram */
  .instagram-section {
    background: var(--color-bone);
  }

  .instagram-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .instagram-embed {
    min-width: 0;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .instagram-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .instagram-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* CTA */
  .cta {
    background: var(--color-white);
    padding: 7rem 0;
  }

  @media (min-width: 768px) {
    .cta {
      padding: 10rem 0;
    }
  }
</style>
