---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const homeEntry = await getEntry('pages', 'home');
const { Content } = await render(homeEntry);

const { title, description } = homeEntry.data;

const allProducts = await getCollection('products');
const featured = allProducts.filter(p => p.data.featured);

function formatPrice(price) {
  return new Intl.NumberFormat('en-GB', {
    style: 'currency',
    currency: 'GBP',
    minimumFractionDigits: 0,
  }).format(price);
}
---

<BaseLayout title={title} description={description}>
  <!-- Full-Screen Video Hero -->
  <section class="hero-video">
    <video autoplay muted loop playsinline class="hero-video__vid" poster="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=1600&q=80&fit=crop">
      <source src="https://videos.pexels.com/video-files/5721025/5721025-uhd_2560_1440_25fps.mp4" type="video/mp4" />
    </video>
    <div class="hero-video__overlay">
      <p class="hero-video__caption">Curated Luxury</p>
      <h1 class="hero-video__title">{title}</h1>
      <div class="hero-video__divider"></div>
      <p class="hero-video__subtitle">Timeless elegance for the modern woman</p>
      <a href="/shop" class="hero-video__cta">Explore the Collection</a>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="section">
    <div class="container text-center">
      <p class="caption reveal">The Ethos</p>
      <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
      <div class="prose reveal reveal--delay-2" style="max-width: 650px; margin: 0 auto;">
        <Content />
      </div>
    </div>
  </section>

  <!-- Featured Products — Asymmetric Editorial Grid -->
  <section class="section editorial-section">
    <div class="container">
      <div class="text-center">
        <p class="caption reveal">Selected Pieces</p>
        <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
        <h2 class="reveal reveal--delay-2">The Edit</h2>
      </div>
      <div class="editorial-grid">
        {featured.map((product, i) => (
          <a
            href={`/products/${product.id}`}
            class={`editorial-card editorial-card--${i + 1} reveal reveal--delay-${i + 1}`}
          >
            <div class="editorial-card__image">
              {product.data.image ? (
                <img src={product.data.image} alt={product.data.name} loading="lazy" />
              ) : (
                <span class="caption">{product.data.category}</span>
              )}
            </div>
            <div class="editorial-card__info">
              <h3>{product.data.name}</h3>
              <span class="editorial-card__price">{formatPrice(product.data.price)}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center reveal" style="margin-top: 3.5rem;">
        <a href="/shop" class="btn">View All</a>
      </div>
    </div>
  </section>

  <!-- Instagram Section -->
  <section class="section instagram-section">
    <div class="container text-center">
      <p class="caption reveal">Follow the Journey</p>
      <div class="accent-line reveal reveal--delay-1" style="margin: 1rem auto;"></div>
      <h2 class="reveal reveal--delay-2">@styleddbymaryam</h2>
      <p class="reveal reveal--delay-3" style="margin: 1rem auto 2.5rem; max-width: 450px;">Behind the scenes, styling tips, and new arrivals — straight from Maryam.</p>

      <div class="ig-grid">
        <a href="https://www.instagram.com/styleddbymaryam/reel/DQMLfvQADQ_/" target="_blank" rel="noopener noreferrer" class="ig-card reveal">
          <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=500&q=80&fit=crop" alt="Style by Maryam — Editorial look" loading="lazy" />
          <div class="ig-card__overlay">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="white" stroke="none"/></svg>
          </div>
        </a>
        <a href="https://www.instagram.com/styleddbymaryam/reel/DP6QGIuiOs0/" target="_blank" rel="noopener noreferrer" class="ig-card reveal reveal--delay-1">
          <img src="https://images.unsplash.com/photo-1496747611176-843222e1e57c?w=500&q=80&fit=crop" alt="Style by Maryam — Evening wear" loading="lazy" />
          <div class="ig-card__overlay">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="white" stroke="none"/></svg>
          </div>
        </a>
        <a href="https://www.instagram.com/styleddbymaryam/reel/DOaoOCmADyn/" target="_blank" rel="noopener noreferrer" class="ig-card reveal reveal--delay-2">
          <img src="https://images.unsplash.com/photo-1487222477894-8943e31ef7b2?w=500&q=80&fit=crop" alt="Style by Maryam — Tailored look" loading="lazy" />
          <div class="ig-card__overlay">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="white" stroke="none"/></svg>
          </div>
        </a>
        <a href="https://www.instagram.com/styleddbymaryam/reel/DOBLAYTgB-Z/" target="_blank" rel="noopener noreferrer" class="ig-card reveal reveal--delay-3">
          <img src="https://images.unsplash.com/photo-1485462537746-965f33f7f6a7?w=500&q=80&fit=crop" alt="Style by Maryam — Accessories" loading="lazy" />
          <div class="ig-card__overlay">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="white" stroke="none"/></svg>
          </div>
        </a>
      </div>

      <a
        href="https://www.instagram.com/styleddbymaryam/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn reveal"
        style="margin-top: 3rem;"
      >
        Follow on Instagram
      </a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section newsletter-section">
    <div class="container text-center">
      <h2 class="reveal">Be the First to Know</h2>
      <p class="reveal reveal--delay-1" style="margin: 1rem auto 2rem; max-width: 450px;">Sign up for exclusive access to new arrivals, private sales, and styling insights from Maryam.</p>
      <form class="newsletter-form reveal reveal--delay-2" onsubmit="event.preventDefault(); this.querySelector('button').textContent = 'Thank You'; this.querySelector('input').disabled = true;">
        <input type="email" placeholder="Your email address" class="newsletter-input" required />
        <button type="submit" class="btn btn--filled newsletter-btn">Subscribe</button>
      </form>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="section cta">
    <div class="container text-center">
      <h2 class="reveal">Explore the Collection</h2>
      <p class="reveal reveal--delay-1" style="margin: 1.5rem auto;">Discover pieces selected for their craft, quality, and quiet confidence.</p>
      <a href="/shop" class="btn reveal reveal--delay-2" style="margin-top: 0.5rem;">Shop Now</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Full-Screen Video Hero */
  .hero-video {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    min-height: 500px;
    overflow: hidden;
  }

  .hero-video__vid {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-video__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.35);
    text-align: center;
    padding: 2rem;
  }

  .hero-video__caption {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1.25rem;
  }

  .hero-video__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 6rem);
    font-style: italic;
    font-weight: 300;
    color: var(--color-white);
    letter-spacing: 0.02em;
    margin: 0;
    line-height: 1.05;
  }

  .hero-video__divider {
    width: 50px;
    height: 1px;
    background: var(--color-gold);
    margin: 1.5rem auto;
  }

  .hero-video__subtitle {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-style: italic;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 2.5rem;
    max-width: none;
  }

  .hero-video__cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 1rem 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.6);
    color: var(--color-white);
    transition: all 0.4s var(--ease-luxury);
  }

  .hero-video__cta:hover {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-white);
  }

  /* Editorial Grid */
  .editorial-section {
    background: var(--color-white);
  }

  .editorial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  .editorial-card {
    display: block;
    text-align: center;
  }

  .editorial-card__image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-bone);
    margin-bottom: 1.25rem;
  }

  .editorial-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-luxury), filter 0.6s var(--ease-luxury);
  }

  .editorial-card:hover .editorial-card__image img {
    transform: scale(1.04);
    filter: brightness(1.05);
  }

  .editorial-card__info {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: 1.5rem;
  }

  .editorial-card__info h3 {
    font-size: 0.85rem;
  }

  .editorial-card__price {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 300;
    color: #888;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .editorial-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* Instagram */
  .instagram-section {
    background: var(--color-bone);
  }

  .ig-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .ig-card {
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .ig-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-luxury), filter 0.5s var(--ease-luxury);
  }

  .ig-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0);
    transition: background 0.4s var(--ease-luxury);
  }

  .ig-card__overlay svg {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.3s, transform 0.3s var(--ease-luxury);
  }

  .ig-card:hover img {
    transform: scale(1.06);
    filter: brightness(0.85);
  }

  .ig-card:hover .ig-card__overlay {
    background: rgba(0, 0, 0, 0.2);
  }

  .ig-card:hover .ig-card__overlay svg {
    opacity: 1;
    transform: scale(1);
  }

  @media (min-width: 768px) {
    .ig-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.5rem;
    }
  }

  /* Newsletter */
  .newsletter-section {
    background: var(--color-black);
    padding: 6rem 0;
  }

  .newsletter-section h2 {
    color: var(--color-white);
  }

  .newsletter-section p {
    color: #999;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 450px;
    margin: 0 auto;
  }

  .newsletter-input {
    width: 100%;
    padding: 1rem 0;
    border: none;
    border-bottom: 1px solid #444;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-white);
    outline: none;
    text-align: center;
    letter-spacing: 0.02em;
    transition: border-color 0.3s;
  }

  .newsletter-input:focus {
    border-bottom-color: var(--color-gold);
  }

  .newsletter-input::placeholder {
    color: #666;
  }

  .newsletter-btn {
    border-color: var(--color-white);
    color: var(--color-white);
  }

  .newsletter-btn:hover {
    background: var(--color-gold);
    border-color: var(--color-gold);
  }

  @media (min-width: 768px) {
    .newsletter-form {
      flex-direction: row;
      gap: 0;
    }

    .newsletter-input {
      text-align: left;
      flex: 1;
      border-bottom: 1px solid #444;
    }

    .newsletter-btn {
      flex-shrink: 0;
      border: 1px solid var(--color-white);
      border-left: none;
    }
  }

  /* CTA */
  .cta {
    background: var(--color-white);
    padding: 7rem 0;
  }

  @media (min-width: 768px) {
    .cta {
      padding: 10rem 0;
    }
  }
</style>
