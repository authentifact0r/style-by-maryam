---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const homeEntry = await getEntry('pages', 'home');
const { Content } = await render(homeEntry);

const { title, description } = homeEntry.data;

const allProducts = await getCollection('products');
const featured = allProducts.filter(p => p.data.featured);

function formatPrice(price) {
  return new Intl.NumberFormat('en-GB', {
    style: 'currency',
    currency: 'GBP',
    minimumFractionDigits: 0,
  }).format(price);
}
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="hero section--hero">
    <div class="container">
      <p class="hero__caption">Curated Luxury</p>
      <h1 class="hero__title">{title}</h1>
      <div class="divider"></div>
      <p class="hero__subtitle">Timeless elegance for the modern woman</p>
    </div>
  </section>

  <!-- Hero Image Band -->
  <section class="hero-image">
    <img
      src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=1600&q=80&fit=crop"
      alt="Luxury fashion editorial"
      class="hero-image__img"
      loading="eager"
    />
  </section>

  <!-- Brand Story -->
  <section class="section">
    <div class="container text-center">
      <p class="caption">The Ethos</p>
      <div class="accent-line" style="margin: 1rem auto;"></div>
      <div class="prose" style="max-width: 700px; margin: 0 auto;">
        <Content />
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section collections">
    <div class="container">
      <div class="text-center">
        <p class="caption">Selected Pieces</p>
        <div class="accent-line" style="margin: 1rem auto;"></div>
        <h2>The Edit</h2>
      </div>
      <div class="collections__grid">
        {featured.map(product => (
          <a href={`/products/${product.id}`} class="collection-card">
            <div class="collection-card__image">
              {product.data.image ? (
                <img src={product.data.image} alt={product.data.name} loading="lazy" />
              ) : (
                <span class="caption">{product.data.category}</span>
              )}
            </div>
            <h3 class="collection-card__title">{product.data.name}</h3>
            <p class="collection-card__price">{formatPrice(product.data.price)}</p>
          </a>
        ))}
      </div>
      <div class="text-center" style="margin-top: 3rem;">
        <a href="/shop" class="btn">View All</a>
      </div>
    </div>
  </section>

  <!-- Instagram Section -->
  <section class="section instagram-section">
    <div class="container text-center">
      <p class="caption">Follow the Journey</p>
      <div class="accent-line" style="margin: 1rem auto;"></div>
      <h2>@styleddbymaryam</h2>
      <p style="margin: 1rem auto 3rem; max-width: 500px;">Behind the scenes, styling tips, and new arrivals — straight from Maryam.</p>

      <div class="instagram-grid">
        <div class="instagram-embed">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DH0IVdONfSj/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
        <div class="instagram-embed">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DHxkYP6tRSV/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
        <div class="instagram-embed">
          <blockquote
            class="instagram-media"
            data-instgrm-captioned
            data-instgrm-permalink="https://www.instagram.com/reel/DHs7dINNVb4/"
            data-instgrm-version="14"
            style="background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 0 auto; max-width:540px; min-width:326px; padding:0; width:100%;">
          </blockquote>
        </div>
      </div>

      <a
        href="https://www.instagram.com/styleddbymaryam/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn"
        style="margin-top: 3rem;"
      >
        Follow on Instagram
      </a>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="section cta">
    <div class="container text-center">
      <h2>Explore the Collection</h2>
      <p style="margin: 1.5rem auto;">Discover pieces selected for their craft, quality, and quiet confidence.</p>
      <a href="/shop" class="btn" style="margin-top: 1rem;">Shop Now</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero__caption {
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    margin-bottom: 0;
  }

  .hero__subtitle {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: #666;
    margin-top: 0.5rem;
  }

  /* Hero Image */
  .hero-image {
    width: 100%;
    height: 60vh;
    min-height: 300px;
    max-height: 700px;
    overflow: hidden;
  }

  .hero-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Collections Grid */
  .collections__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .collection-card {
    text-align: center;
  }

  .collection-card__image {
    aspect-ratio: 3 / 4;
    background: linear-gradient(180deg, #ece7df 0%, #ddd6ca 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: opacity 0.3s ease;
  }

  .collection-card:hover .collection-card__image {
    opacity: 0.85;
  }

  .collection-card__title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .collection-card__price {
    font-family: 'Helvetica Neue', 'Arial', sans-serif;
    font-size: 0.85rem;
    color: #888;
    margin-top: 0.25rem;
  }

  .collection-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-card:hover .collection-card__image img {
    transform: scale(1.03);
  }

  /* Instagram Section */
  .instagram-section {
    background: #fff;
  }

  .instagram-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .instagram-embed {
    min-width: 0;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .instagram-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  /* CTA */
  .cta {
    background: #f5f1eb;
    padding: 6rem 0;
  }

  @media (min-width: 768px) {
    .collections__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }

    .cta {
      padding: 8rem 0;
    }
  }
</style>
