{
  "redirects": [
    { "source": "/admin", "destination": "https://authentifactor.com/admin?tenant=styled-by-maryam", "permanent": false },
    { "source": "/admin/:path*", "destination": "https://authentifactor.com/admin/:path*?tenant=styled-by-maryam", "permanent": false },
    { "source": "/login", "destination": "https://authentifactor.com/login?tenant=styled-by-maryam", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' https:; connect-src 'self' https:; frame-ancestors 'self'" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "X-XSS-Protection", "value": "0" }
      ]
    }
  ]
}
